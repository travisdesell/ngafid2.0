{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "jsx": "react-jsx",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "skipLibCheck": true,
        "allowJs": false,
        "checkJs": false,
        "noEmit": true,
        "lib": ["DOM", "WebWorker", "ESNext"],
        "paths": {
            "@/*": ["./src/app/*"],
            "@": ["./src/app"]
        },
        "types": ["vite/client"],
        "rootDir": "./src"
    },
    "include": [
        "src/**/*",
        "src/app/src/**/*"
    ]
}