#!/bin/bash

# Backfill TTF cache: delete outdated entries and recompute.
# Run after deployments that change TurnToFinal.serialVersionUID.
#
# Run from repo root: ./run/backfill/backfill_ttf [--full] [--batch N] [--limit N] [--dry-run]
# --full: pre-populate from itinerary (all flights with approach data), not just cached ones

JAR_PATH="ngafid-core/target/ngafid-core-1.0-SNAPSHOT-jar-with-dependencies.jar"

if [ ! -f "$JAR_PATH" ]; then
    echo "Error: JAR file not found at $JAR_PATH"
    echo "Please build the project first: mvn clean package"
    exit 1
fi

java -cp "$JAR_PATH" org.ngafid.core.bin.BackfillTTFCache "$@"
