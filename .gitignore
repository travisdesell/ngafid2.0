# IDE and OS generated files:
.DS_Store
.idea
.vscode/


# Symlink to where data is actually located:
data


# Data stored in the repository for local development:
data/*


# File/data backups:
backups/*


# Front-end stuff:
.cache-loader/*
src/main/resources/public/js/*
ngafid-frontend/node_modules
ngafid-frontend/.webpack_cache/*
ngafid-static/js/*


# Java build artifacts:
*/target/*


# Generated charts:
ngafid-chart-processor/charts/*
ngafid-chart-processor/temp


# Chart processor raw images:
*.tif


# Database files/configuration:
ngafid-db/src/liquibase.properties
ngafid-db/src/liquibase.docker.properties


# Environment variable files:
ngafid.properties
.env
.env.host


# Email configuration files:
ngafid-email.conf
email_info.txt


# Log files:
*.log
log
# INCLUDE example log file for validation logs:
!validationlog_EXAMPLE.log


# All files/folders containing 'IGNORE' in their name:
**IGNORE**